  "totalSteps": 11,
  "lessons": [
    {
      "stepNumber": 1,
      "type": "single_expression",
      "expression": {
        "korean": "___고 생각해요",
        "romanization": "___go saenggakaeyo",
        "meaning": "I think ___",
        "explanation": "자신의 의견이나 생각을 표현할 때 사용해요.",
        "whenToUse": "의견을 말할 때",
        "examples": [
          {
            "korean": "좋은 생각이라고 생각해요.",
            "romanization": "joeun saenggagirago saenggakaeyo.",
            "meaning": "I think it's a good idea."
          },
          {
            "korean": "어렵다고 생각해요.",
            "romanization": "eoryeopdago saenggakaeyo.",
            "meaning": "I think it's difficult."
          }
        ],
        "culturalTip": "'-라고/다고 생각하다'로 간접적으로 의견을 표현해요.",
        "explanationEn": "It is used when expressing one's opinions or thoughts.",
        "whenToUseEn": "\"When expressing an opinion\"",
        "culturalTipEn": "The phrase '-라고/다고 생각하다' is used to indirectly express an opinion."
      }
    },
    {
      "stepNumber": 2,
      "type": "single_expression",
      "expression": {
