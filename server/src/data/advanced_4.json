        "whenToUseEn": "\"When You Need Advice\"",
        "culturalTipEn": "\"When you're feeling flustered, you can ask for help with this expression.\""
      }
    },
    {
      "stepNumber": 6,
      "type": "single_expression",
      "expression": {
        "korean": "신고하다",
        "romanization": "singohada",
        "meaning": "To report",
