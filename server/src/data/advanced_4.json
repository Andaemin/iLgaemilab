{
  "title": "문제 상황 대처",
  "subtitle": "한국어로 문제 상황에 대처하는 방법을 배워요",
  "totalSteps": 11,
  "lessons": [
    {
      "stepNumber": 1,
      "type": "single_expression",
      "expression": {
        "korean": "도와주세요",
        "romanization": "dowajuseyo",
        "meaning": "Please help me",
        "explanation": "도움이 필요할 때 사용하는 표현이에요.",
        "whenToUse": "긴급하게 도움이 필요할 때",
        "examples": [
          {
            "korean": "도와주세요! 길을 잃었어요.",
            "romanization": "dowajuseyo! gireul ireosseoyo.",
            "meaning": "Please help me! I'm lost."
          },
          {
            "korean": "좀 도와주시겠어요?",
            "romanization": "jom dowajusigesseoyo?",
            "meaning": "Could you help me a bit?"
          }
        ],
        "culturalTip": "한국 사람들은 도움을 요청하면 기꺼이 도와줘요!",
        "explanationEn": "This is an expression used when you need help.",
        "whenToUseEn": "\"When you urgently need help\"",
        "culturalTipEn": "Koreans are always willing to help when you ask for assistance!"
      }
    },
    {
      "stepNumber": 2,
      "type": "single_expression",
      "expression": {
        "korean": "문제가 있어요",
        "romanization": "munjega isseoyo",
        "meaning": "There's a problem",
        "explanation": "문제나 어려움이 생겼을 때 사용해요.",
        "whenToUse": "문제 상황을 알릴 때",
        "examples": [
          {
            "korean": "큰 문제가 있어요.",
            "romanization": "keun munjega isseoyo.",
            "meaning": "There's a big problem."
          },
          {
            "korean": "무슨 문제가 있어요?",
            "romanization": "museun munjega isseoyo?",
            "meaning": "What's the problem?"
          }
        ],
        "culturalTip": "문제를 명확하게 설명하면 더 빨리 도움을 받을 수 있어요.",
        "explanationEn": "\"We use it when a problem or difficulty arises.\"",
        "whenToUseEn": "When Informing About a Problem Situation",
        "culturalTipEn": "If you explain the problem clearly, you can get help more quickly."
      }
    },
    {
      "stepNumber": 3,
      "type": "single_expression",
      "expression": {
        "korean": "___을/를 잃어버렸어요",
        "romanization": "___eul/reul ireobeoryeosseoyo",
        "meaning": "I lost ___",
        "explanation": "물건을 잃어버렸을 때 사용하는 표현이에요.",
        "whenToUse": "분실물을 신고할 때",
        "examples": [
          {
            "korean": "지갑을 잃어버렸어요.",
            "romanization": "jigabeul ireobeoryeosseoyo.",
            "meaning": "I lost my wallet."
          },
          {
            "korean": "휴대폰을 잃어버렸어요. 어떻게 해요?",
            "romanization": "hyudaeponeul ireobeoryeosseoyo. eotteoke haeyo?",
            "meaning": "I lost my phone. What should I do?"
          }
        ],
        "culturalTip": "분실물 센터는 '분실물 보관소'라고 해요!",
        "explanationEn": "This is an expression used when you have lost an item.",
        "whenToUseEn": "When Reporting Lost Items",
        "culturalTipEn": "The lost and found center is called a \"lost property storage.\""
      }
    },
    {
      "stepNumber": 4,
      "type": "single_expression",
      "expression": {
