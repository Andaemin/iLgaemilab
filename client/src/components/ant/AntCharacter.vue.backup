/* 픽셀 애니메이션 */
@keyframes pixelBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

@keyframes pixelWiggle {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(-2px) rotate(-2deg); }
  75% { transform: translateX(2px) rotate(2deg); }
}

@keyframes pixelPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes pixelGlow {
  0%, 100% { filter: brightness(1) drop-shadow(0 0 5px rgba(255, 215, 0, 0.3)); }
  50% { filter: brightness(1.2) drop-shadow(0 0 10px rgba(255, 215, 0, 0.6)); }
}

/* 전체 애니메이션 */
.ant-stage {
  animation: pixelFloat 3s ease-in-out infinite !important;
}

@keyframes pixelFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

/* 클릭 시 픽셀 점프 */
.ant-character.is-happy .ant-stage {
  animation: pixelJump 0.4s ease-out !important;
}

@keyframes pixelJump {
  0% { transform: scale(1) translateY(0); }
  50% { transform: scale(1.1) translateY(-12px); }
  100% { transform: scale(1) translateY(0); }
}

/* 호버 시 픽셀 효과 */
.ant-container:hover .ant-stage {
  animation: pixelHop 0.5s ease-in-out infinite !important;
  filter: brightness(1.1) !important;
}

@keyframes pixelHop {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}
</style>
