        "whenToUse": "강한 욕구를 표현할 때",
        "examples": [
          {
            "korean": "성공을 원해요.",
            "romanization": "seonggongeul wonhaeyo.",
            "meaning": "I want success."
          },
          {
            "korean": "무엇을 원하세요?",
            "romanization": "mueoseul wonhaseyo?",
            "meaning": "What do you want?"
          }
