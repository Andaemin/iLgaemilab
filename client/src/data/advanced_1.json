    {
      "stepNumber": 3,
      "type": "single_expression",
      "expression": {
        "korean": "직진하세요 / 돌아가세요",
        "romanization": "jikjinhaseyo / doragaseyo",
        "meaning": "Go straight / Turn around",
        "explanation": "길 안내할 때 사용하는 기본 방향 지시예요.",
        "whenToUse": "길을 안내할 때",
